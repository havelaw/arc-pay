{
  "functions": {
    "api/parse-receipt.js": {
      "maxDuration": 30
    },
    "api/parse-receipt-paid.js": {
      "maxDuration": 30
    },
    "api/agent-pay.js": {
      "maxDuration": 60
    },
    "api/agent-info.js": {
